# Cloudflare Tunnel config for Crafty Controller
#
# Copy this to /root/.cloudflared/config.yml and replace the placeholders:
#   <YOUR_TUNNEL_UUID>     - printed by `cloudflared tunnel create crafty`
#   crafty.YOUR_DOMAIN.com - the subdomain you ran `cloudflared tunnel route dns` for

tunnel: <YOUR_TUNNEL_UUID>
credentials-file: /root/.cloudflared/<YOUR_TUNNEL_UUID>.json

ingress:
  # Crafty's web UI, served over HTTPS on localhost with a self-signed cert.
  # noTLSVerify is required because the cert is self-signed and the hostname
  # doesn't match. This is safe because both ends are on the same machine.
  - hostname: crafty.YOUR_DOMAIN.com
    service: https://127.0.0.1:8443
    originRequest:
      noTLSVerify: true

  # Catch-all: anything not matched above returns 404.
  - service: http_status:404
